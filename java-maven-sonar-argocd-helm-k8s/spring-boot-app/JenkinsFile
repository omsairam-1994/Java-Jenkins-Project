pipeline {
  agent any
  parameters {
    choice(
      name: 'RUN_MODE',
      choices: ['ALL', 'FAILED_ONLY'],
      description: 'Choose whether to run all stages or only rerun failed ones'
    )
  }
  environment {
    JAVA_HOME = "/usr/lib/jvm/java-17-openjdk-amd64"
    PATH = "${JAVA_HOME}/bin:${env.PATH}"
  }

  stages {
    stage('Cleanup') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      steps {
        cleanWs()
      }
    }

    stage('Checkout') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      steps {
        git branch: 'main', url: 'https://github.com/omsairam-1994/Java-Jenkins-Project.git'
      }
    }

    stage('GitLeaks Scan') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      steps {
        sh '/usr/local/bin/gitleaks detect --source . --no-banner --exit-code 1'
      }
    }

    stage('Build and Test') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      steps {
        sh '''
          cd java-maven-sonar-argocd-helm-k8s/spring-boot-app || exit 1
          mvn clean package
        '''
      }
    }

    stage('Static Code Analysis') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      environment {
        SONAR_URL = "http://192.168.56.1:9000"
      }
      steps {
        script {
          def sonarReachable = sh(
            script: "curl -s --connect-timeout 5 ${SONAR_URL}/api/system/status | grep -q 'UP'",
            returnStatus: true
          ) == 0

          if (sonarReachable) {
            withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
              sh '''
                cd java-maven-sonar-argocd-helm-k8s/spring-boot-app || exit 1
                mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}
              '''
            }
          } else {
            echo "SonarQube not available, skipping analysis."
          }
        }
      }
    }

    stage('Build and Push Docker Image') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      environment {
        DOCKER_IMAGE = "punnarao/java-project-pipeline:${BUILD_NUMBER}"
        REGISTRY_CREDENTIALS = credentials('docker-cred')
      }
      steps {
        script {
          sh '''
            cd java-maven-sonar-argocd-helm-k8s/spring-boot-app || exit 1
            docker build -t ${DOCKER_IMAGE} .
          '''
          def dockerImage = docker.image("${DOCKER_IMAGE}")
          docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
            dockerImage.push()
          }
        }
      }
    }

    stage('Trivy Scan') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      steps {
        sh "/usr/bin/trivy image ${DOCKER_IMAGE} --exit-code 1 --severity HIGH,CRITICAL"
      }
    }

    stage('Update Deployment File') {
      when {
        expression { params.RUN_MODE == 'ALL' || currentBuild.result == 'FAILURE' }
      }
      environment {
        GIT_REPO_NAME = "Java-Jenkins-Project"
        GIT_USER_NAME = "omsairam-1994"
      }
      steps {
        withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
          sh '''
            git config user.email "punnaraok7@gmail.com"
            git config user.name "omsairam-1994"
            BUILD_NUMBER=${BUILD_NUMBER}
            sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
            git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
            git commit -m "Update deployment image to version ${BUILD_NUMBER}"
            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
          '''
        }
      }
    }
  }
}
